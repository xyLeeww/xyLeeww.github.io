---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Ava Li — Learning Notes">

  <!-- About -->
  <section id="about" class="bio">
    <h2 class="section-title">About</h2>
    <p>
      Hi! I'm Ava Li. This is my personal learning notes site where I document
      what I learn about <strong>Computer Graphics</strong>,
       <strong>GPU Drivers</strong>, and <strong>Vulkan</strong>.
	  I currently work on graphics driver development at <strong>AMD</strong>.
    </p>
    <p>
      I believe the most effective way to learn is through sharing and discussion.
      Feel free to browse my notes and projects!
    </p>
  </section>
  <!-- Notes -->
  <section id="notes">
    <h2 class="section-title">Notes</h2>
    <ul class="post-list">
      {notes.map((note) => (
        <li class="post-item">
          <span class="post-date">
            {note.data.date.toISOString().slice(0, 10)}
          </span>
          <div class="post-info">
            <h3><a href={`/notes/${note.id}/`}>{note.data.title}</a></h3>
            {note.data.description && (
              <p class="post-desc">{note.data.description}</p>
            )}
            {note.data.tags.length > 0 && (
              <div class="post-tags">
                {note.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
  <!-- Projects -->
  <section id="projects">
    <h2 class="section-title">Projects</h2>
    <div class="project-grid">

      <div class="project-card">
        <h3><a href="#">Vulkan Renderer</a></h3>
        <p>A Vulkan forward/deferred rendering pipeline built from scratch, with PBR materials and shadow mapping.</p>
        <div class="project-links">
          <a href="https://github.com/xyLeeww/GPUDebugToolkit">Code</a>
          <a href="#">Docs</a>
        </div>
      </div>

      <div class="project-card">
        <h3><a href="#">Ray Tracing Lab</a></h3>
        <p>Software vs hardware ray tracing comparison using Vulkan Ray Tracing extensions.</p>
        <div class="project-links">
          <a href="#">Code</a>
          <a href="#">Blog</a>
        </div>
      </div>

      <div class="project-card">
        <h3><a href="#">GPU Debug Toolkit</a></h3>
        <p>Automated diagnostic scripts for analyzing GPU hang/TDR issues.</p>
        <div class="project-links">
          <a href="#">Code</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <h2 class="section-title">Skills</h2>

    <div class="skill-group">
      <h3>Languages</h3>
      <div class="tags">
        <span class="tag">C++</span>
        <span class="tag">Python</span>
        <span class="tag">GLSL</span>
        <span class="tag">HLSL</span>
      </div>
    </div>

    <div class="skill-group">
      <h3>Graphics &amp; GPU</h3>
      <div class="tags">
        <span class="tag">Vulkan</span>
        <span class="tag">OpenGL</span>
        <span class="tag">Rasterization</span>
        <span class="tag">Ray Tracing</span>
      </div>
    </div>

    <div class="skill-group">
      <h3>Tools</h3>
      <div class="tags">
        <span class="tag">WinDbg</span>
        <span class="tag">RenderDoc</span>
      </div>
    </div>
  </section>
</BaseLayout>
